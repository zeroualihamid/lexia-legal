# ─── Dependencies & build ───────────────────────────────────
**/node_modules/
**/dist/
**/build/
**/out/
**/dist-ssr/
coverage/
*.tsbuildinfo

# ─── Secrets & env (keep *.example tracked) ─────────────────
.env
.env.*
!.env.example
!.env.template
!.env.production

# ─── Logs & runtime ──────────────────────────────────────────
**/logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-store/

# ─── OS / editor ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.orig

# ─── Local AI / agent tooling (not app source) ───────────────
.agents/
skills-lock.json

# ─── Backups & local overrides ───────────────────────────────
*.bak
.railwayignore.bak

# ─── Python (lexia-agent and scripts) ────────────────────────
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
**/venv/
**/*.egg-info/
**/.eggs/
uv.lock

# ─── SSL / credentials ───────────────────────────────────────
infra/nginx/certs/*.pem
infra/nginx/certs/*.key
*.pem
*.key
!infra/nginx/certs/.gitkeep

# ─── Puppeteer / browser cache ───────────────────────────────
.cache/
.puppeteer/

# ─── Optional local tooling ──────────────────────────────────
.turbo/

# ─── Local test fixtures (upload via API → MinIO instead) ────
/data/

# ─── Legacy duplicate (canonical Python agent is lexia-agent/) ─
/agent/

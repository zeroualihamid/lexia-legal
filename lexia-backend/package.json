{
  "name": "lexia-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Unified Lexia backend: legal platform API, better-auth, agent proxy",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint src --ext .ts",
    "migrate": "auth migrate --yes",
    "seed:admin": "node scripts/seed-admin.mjs",
    "seed:admin:docker": "docker compose -f deploy/docker-compose.yml exec -T lexia-backend node scripts/seed-admin.mjs",
    "dev:db": "docker compose -f deploy/docker-compose.yml up -d postgres redis qdrant minio keycloak postgres-keycloak",
    "dev:db:down": "docker compose -f deploy/docker-compose.yml stop postgres redis qdrant minio keycloak postgres-keycloak"
  },
  "dependencies": {
    "@bull-board/api": "^5.0.0",
    "@bull-board/express": "^5.0.0",
    "@nestjs/bull": "^10.0.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@qdrant/js-client-rest": "^1.9.0",
    "auth": "^1.6.11",
    "axios": "^1.6.0",
    "better-auth": "^1.6.11",
    "bull": "^4.0.0",
    "bullmq": "^5.78.0",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "http-proxy-middleware": "^3.0.3",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.0",
    "jwks-rsa": "^3.1.0",
    "minio": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.0.0",
    "pg": "^8.13.0",
    "playwright": "^1.49.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.0.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/crypto-js": "^4.2.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.0"
  }
}

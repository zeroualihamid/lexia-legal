#!/usr/bin/env bash
# qsql — run one SQL statement against the parquet cache AND the live Oracle,
# side-by-side, from inside the lexia-agent container on this VM.
#
# Designed to be run ON THE VM after `ssh uadmin@<vm>`. For the equivalent
# Mac-side remote invocation, see `deploy.sh compare`.
#
# Usage:
#   ./qsql "SELECT COUNT(*) FROM {table} WHERE EXERSTAT = 2026"
#   ./qsql --preset sum_by_year
#   ./qsql --only parquet "SELECT MIN(PRIMNETT) FROM {table}"
#   ./qsql --list-presets
#
# Placeholders in the SQL (see compare_parquet_oracle.py for details):
#   {table}   → Oracle table name on the Oracle side, DuckDB view on parquet
#   {oracle}  → raw Oracle table name
#   {parquet} → raw DuckDB view name
#
# Env overrides:
#   LEXIA_CONTAINER   container name (default: lexia-legal-agent)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PY_SCRIPT="$SCRIPT_DIR/compare_parquet_oracle.py"
CONTAINER="${LEXIA_CONTAINER:-lexia-legal-agent}"

if [[ ! -f "$PY_SCRIPT" ]]; then
    echo "qsql: missing companion script: $PY_SCRIPT" >&2
    echo "      expected it next to this file; re-run 'deploy.sh ship' from the Mac" >&2
    exit 1
fi

if ! docker inspect "$CONTAINER" >/dev/null 2>&1; then
    echo "qsql: container '$CONTAINER' not running on this host" >&2
    echo "      (override with LEXIA_CONTAINER=<name>)" >&2
    exit 1
fi

# If the first argument isn't a flag, treat it as the SQL query and prepend --query
# so you can write `./qsql "SELECT ..."` instead of `./qsql --query "SELECT ..."`.
if [[ $# -gt 0 && "$1" != -* ]]; then
    set -- --query "$@"
fi

docker cp "$PY_SCRIPT" "$CONTAINER:/tmp/compare_parquet_oracle.py" >/dev/null
exec docker exec -i "$CONTAINER" python /tmp/compare_parquet_oracle.py "$@"

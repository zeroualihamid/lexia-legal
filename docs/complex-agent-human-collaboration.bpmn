<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_ComplexAgentHumanCollaboration" targetNamespace="https://lexia-legal.local/bpmn/complex-agent-human-collaboration" exporter="Camunda Modeler" exporterVersion="5.48.0">
  <bpmn:process id="Process_ComplexAgentHumanCollaboration" name="Complex agent work with human control and trust" isExecutable="false">
    <bpmn:documentation>Workflow distilled from the transcript: chat or voice can start complex work, but trust and control come from verifiability checks, decomposition, guardrails, skills, decision logs, durable artifacts, and targeted human review.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_AgentCollaboration">
      <bpmn:lane id="Lane_Workers" name="Sub-agents, tools, verifiers">
        <bpmn:flowNodeRef>Task_ResearchRetrieve</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ApplySkills</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DraftWork</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RunVerification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FixVerifierFailures</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Uncertainty</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ContinueAfterUncertainty</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_VerificationPassed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Orchestrator" name="Agent orchestrator">
        <bpmn:flowNodeRef>Task_Intake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AssessVerifiability</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DefineAutomatedVerification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DecomposeTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DefineProxyChecks</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SetGuardrails</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CreatePlanArtifact</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DispatchWorkTree</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MakeTentativeDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LogDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PublishArtifact</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ApplyTargetedChanges</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdatePlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_VerificationStrategyReady</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_CanVerify</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Human" name="Human reviewer / domain expert">
        <bpmn:flowNodeRef>Task_ProvideObjective</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReviewPlanArtifact</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReviewArtifactDecisionLog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GiveTargetedFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AddDomainJudgment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DeliverableAccepted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Accepted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PlanApproved</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Request" name="Complex work requested" />
    <bpmn:task id="Task_ProvideObjective" name="Submit objective, constraints, and source material" />
    <bpmn:task id="Task_Intake" name="Capture request from chat or voice input" />
    <bpmn:task id="Task_AssessVerifiability" name="Classify task by verifiability and risk" />
    <bpmn:exclusiveGateway id="Gateway_CanVerify" name="Can the task be made verifiable?" />
    <bpmn:task id="Task_DefineAutomatedVerification" name="Define tests or objective verifiers" />
    <bpmn:task id="Task_DecomposeTask" name="Decompose hard judgment into smaller work nodes" />
    <bpmn:task id="Task_DefineProxyChecks" name="Define proxy checks from golden examples" />
    <bpmn:exclusiveGateway id="Gateway_VerificationStrategyReady" name="Verification strategy ready" />
    <bpmn:task id="Task_SetGuardrails" name="Set guardrails for files, sources, tools, and actions" />
    <bpmn:task id="Task_CreatePlanArtifact" name="Create plan and review artifact" />
    <bpmn:task id="Task_ReviewPlanArtifact" name="Review plan artifact and align approach" />
    <bpmn:exclusiveGateway id="Gateway_PlanApproved" name="Approach aligned?" />
    <bpmn:task id="Task_AddDomainJudgment" name="Add domain judgment, risk profile, or negotiation stance" />
    <bpmn:task id="Task_UpdatePlan" name="Update plan, constraints, and work tree" />
    <bpmn:task id="Task_DispatchWorkTree" name="Run work tree and dispatch sub-agents" />
    <bpmn:task id="Task_ResearchRetrieve" name="Research, read, search, and retrieve materials" />
    <bpmn:task id="Task_ApplySkills" name="Apply skills and domain rules at each work node" />
    <bpmn:task id="Task_DraftWork" name="Draft, edit, format, or analyze output" />
    <bpmn:exclusiveGateway id="Gateway_Uncertainty" name="Uncertainty or special case?" />
    <bpmn:task id="Task_MakeTentativeDecision" name="Choose default to stay unblocked" />
    <bpmn:task id="Task_LogDecision" name="Log decision, rationale, and reversal point" />
    <bpmn:exclusiveGateway id="Gateway_ContinueAfterUncertainty" name="Continue execution" />
    <bpmn:task id="Task_RunVerification" name="Run verifiers, linting, and similarity checks" />
    <bpmn:exclusiveGateway id="Gateway_VerificationPassed" name="Checks passed?" />
    <bpmn:task id="Task_FixVerifierFailures" name="Fix verifier failures and rerun work node" />
    <bpmn:task id="Task_PublishArtifact" name="Publish durable artifact for review" />
    <bpmn:task id="Task_ReviewArtifactDecisionLog" name="Review artifact and decision log" />
    <bpmn:exclusiveGateway id="Gateway_DeliverableAccepted" name="Deliverable accepted?" />
    <bpmn:task id="Task_GiveTargetedFeedback" name="Annotate clause, cell, section, or issue" />
    <bpmn:task id="Task_ApplyTargetedChanges" name="Apply targeted change without rewriting unrelated work" />
    <bpmn:endEvent id="EndEvent_Accepted" name="Final deliverable accepted" />
    <bpmn:dataObject id="DataObject_DecisionLog" name="Decision log" />
    <bpmn:dataObjectReference id="DataObjectReference_DecisionLog" name="Decision log" dataObjectRef="DataObject_DecisionLog" />
    <bpmn:dataObject id="DataObject_DurableArtifact" name="Durable artifact" />
    <bpmn:dataObjectReference id="DataObjectReference_DurableArtifact" name="Document or tabular review" dataObjectRef="DataObject_DurableArtifact" />
    <bpmn:sequenceFlow id="Flow_RequestToObjective" sourceRef="StartEvent_Request" targetRef="Task_ProvideObjective" />
    <bpmn:sequenceFlow id="Flow_ObjectiveToIntake" sourceRef="Task_ProvideObjective" targetRef="Task_Intake" />
    <bpmn:sequenceFlow id="Flow_IntakeToAssess" sourceRef="Task_Intake" targetRef="Task_AssessVerifiability" />
    <bpmn:sequenceFlow id="Flow_AssessToCanVerify" sourceRef="Task_AssessVerifiability" targetRef="Gateway_CanVerify" />
    <bpmn:sequenceFlow id="Flow_VerifiablePath" name="Easy to verify" sourceRef="Gateway_CanVerify" targetRef="Task_DefineAutomatedVerification" />
    <bpmn:sequenceFlow id="Flow_HardToVerifyPath" name="Hard to verify" sourceRef="Gateway_CanVerify" targetRef="Task_DecomposeTask" />
    <bpmn:sequenceFlow id="Flow_VerifierToStrategy" sourceRef="Task_DefineAutomatedVerification" targetRef="Gateway_VerificationStrategyReady" />
    <bpmn:sequenceFlow id="Flow_DecomposeToProxy" sourceRef="Task_DecomposeTask" targetRef="Task_DefineProxyChecks" />
    <bpmn:sequenceFlow id="Flow_ProxyToStrategy" sourceRef="Task_DefineProxyChecks" targetRef="Gateway_VerificationStrategyReady" />
    <bpmn:sequenceFlow id="Flow_StrategyToGuardrails" sourceRef="Gateway_VerificationStrategyReady" targetRef="Task_SetGuardrails">
      <bpmn:extensionElements>
        <camunda:executionListener class="" event="take" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GuardrailsToPlan" sourceRef="Task_SetGuardrails" targetRef="Task_CreatePlanArtifact" />
    <bpmn:sequenceFlow id="Flow_PlanToReview" sourceRef="Task_CreatePlanArtifact" targetRef="Task_ReviewPlanArtifact" />
    <bpmn:sequenceFlow id="Flow_ReviewToApprovedGateway" sourceRef="Task_ReviewPlanArtifact" targetRef="Gateway_PlanApproved" />
    <bpmn:sequenceFlow id="Flow_PlanRejected" name="Needs steering" sourceRef="Gateway_PlanApproved" targetRef="Task_AddDomainJudgment" />
    <bpmn:sequenceFlow id="Flow_JudgmentToUpdate" sourceRef="Task_AddDomainJudgment" targetRef="Task_UpdatePlan" />
    <bpmn:sequenceFlow id="Flow_UpdateToReview" sourceRef="Task_UpdatePlan" targetRef="Task_ReviewPlanArtifact" />
    <bpmn:sequenceFlow id="Flow_PlanApproved" name="Aligned" sourceRef="Gateway_PlanApproved" targetRef="Task_DispatchWorkTree" />
    <bpmn:sequenceFlow id="Flow_DispatchToResearch" sourceRef="Task_DispatchWorkTree" targetRef="Task_ResearchRetrieve" />
    <bpmn:sequenceFlow id="Flow_ResearchToSkills" sourceRef="Task_ResearchRetrieve" targetRef="Task_ApplySkills" />
    <bpmn:sequenceFlow id="Flow_SkillsToDraft" sourceRef="Task_ApplySkills" targetRef="Task_DraftWork" />
    <bpmn:sequenceFlow id="Flow_DraftToUncertainty" sourceRef="Task_DraftWork" targetRef="Gateway_Uncertainty" />
    <bpmn:sequenceFlow id="Flow_UncertaintyYes" name="Yes" sourceRef="Gateway_Uncertainty" targetRef="Task_MakeTentativeDecision" />
    <bpmn:sequenceFlow id="Flow_TentativeToLog" sourceRef="Task_MakeTentativeDecision" targetRef="Task_LogDecision" />
    <bpmn:sequenceFlow id="Flow_LogToContinue" sourceRef="Task_LogDecision" targetRef="Gateway_ContinueAfterUncertainty" />
    <bpmn:sequenceFlow id="Flow_UncertaintyNo" name="No" sourceRef="Gateway_Uncertainty" targetRef="Gateway_ContinueAfterUncertainty" />
    <bpmn:sequenceFlow id="Flow_ContinueToVerification" sourceRef="Gateway_ContinueAfterUncertainty" targetRef="Task_RunVerification" />
    <bpmn:sequenceFlow id="Flow_VerificationToGateway" sourceRef="Task_RunVerification" targetRef="Gateway_VerificationPassed" />
    <bpmn:sequenceFlow id="Flow_ChecksFailed" name="Failed" sourceRef="Gateway_VerificationPassed" targetRef="Task_FixVerifierFailures" />
    <bpmn:sequenceFlow id="Flow_FixToDispatch" sourceRef="Task_FixVerifierFailures" targetRef="Task_DispatchWorkTree" />
    <bpmn:sequenceFlow id="Flow_ChecksPassed" name="Passed" sourceRef="Gateway_VerificationPassed" targetRef="Task_PublishArtifact" />
    <bpmn:sequenceFlow id="Flow_PublishToReview" sourceRef="Task_PublishArtifact" targetRef="Task_ReviewArtifactDecisionLog" />
    <bpmn:sequenceFlow id="Flow_ReviewToAcceptance" sourceRef="Task_ReviewArtifactDecisionLog" targetRef="Gateway_DeliverableAccepted" />
    <bpmn:sequenceFlow id="Flow_DeliverableNeedsChanges" name="Needs targeted change" sourceRef="Gateway_DeliverableAccepted" targetRef="Task_GiveTargetedFeedback" />
    <bpmn:sequenceFlow id="Flow_FeedbackToTargetedChange" sourceRef="Task_GiveTargetedFeedback" targetRef="Task_ApplyTargetedChanges" />
    <bpmn:sequenceFlow id="Flow_TargetedChangeToVerification" sourceRef="Task_ApplyTargetedChanges" targetRef="Task_RunVerification" />
    <bpmn:sequenceFlow id="Flow_DeliverableAccepted" name="Accepted" sourceRef="Gateway_DeliverableAccepted" targetRef="EndEvent_Accepted" />
    <bpmn:textAnnotation id="TextAnnotation_HighBandwidth">
      <bpmn:text>Use chat for flexible input; use durable artifacts for high-bandwidth collaboration.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_Guardrails">
      <bpmn:text>Guardrails raise trust by limiting reads, edits, searches, tools, and side effects.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_GuardrailsNote" sourceRef="Task_SetGuardrails" targetRef="TextAnnotation_Guardrails" />
    <bpmn:association id="Association_HighBandwidthNote" sourceRef="TextAnnotation_HighBandwidth" targetRef="Task_ReviewPlanArtifact" />
    <bpmn:association id="Association_LogDecision" sourceRef="Task_LogDecision" targetRef="DataObjectReference_DecisionLog" />
    <bpmn:association id="Association_DecisionLogReview" sourceRef="DataObjectReference_DecisionLog" targetRef="Task_ReviewArtifactDecisionLog" />
    <bpmn:association id="Association_PublishArtifact" sourceRef="Task_PublishArtifact" targetRef="DataObjectReference_DurableArtifact" />
    <bpmn:association id="Association_ArtifactReview" sourceRef="DataObjectReference_DurableArtifact" targetRef="Task_ReviewArtifactDecisionLog" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_ComplexAgentHumanCollaboration">
    <bpmndi:BPMNPlane id="BPMNPlane_ComplexAgentHumanCollaboration" bpmnElement="Process_ComplexAgentHumanCollaboration">

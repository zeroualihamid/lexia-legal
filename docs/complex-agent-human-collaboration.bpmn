      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_RequestToObjective_di" bpmnElement="Flow_RequestToObjective">
        <di:waypoint x="216" y="235" />
        <di:waypoint x="250" y="235" />
      </bpmndi:BPMNEdge>

# Proxy target for Vite dev (not exposed to the browser)
# Docker compose backend (default): :6002 — local NestJS: :3020
VITE_BACKEND_URL=http://localhost:6002

# Leave empty to route /api, /parquet, /skills, … through the Vite proxy (:5175).
# Set VITE_API_URL only when direct cross-origin requests are required.
# VITE_API_URL=http://localhost:3020

VITE_API_URL=

# Lexia Legal admin auth (Keycloak). Set VITE_BETTER_AUTH=1 to use better-auth instead.
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=legal-ai
VITE_KEYCLOAK_CLIENT_ID=legal-ai-frontend
# Legacy compatibility only; new deployments should leave this empty.
VITE_ANALYST_URL=

# Optional: sub-path deploy (e.g. nginx /brikz/)
# VITE_BASE=/brikz/

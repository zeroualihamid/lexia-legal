# ============================================================
# Lexia Legal AI Platform — Environment Variables Template
# Copy this file to .env and fill in the values before running
# ============================================================

# ─── PostgreSQL (Application Database) ───────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=legal_ai
POSTGRES_USER=legal_ai
POSTGRES_PASSWORD=change_me_secure_password

# ─── Keycloak (Identity & Access Management) ─────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=legal-ai
KEYCLOAK_CLIENT_ID=legal-ai-backend
KEYCLOAK_CLIENT_SECRET=change_me
KEYCLOAK_ADMIN_PASSWORD=change_me_admin
KEYCLOAK_DB_PASSWORD=change_me_kc_db

# ─── Redis (Queue & Cache) ────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis

# ─── Qdrant (Vector Database) ────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=change_me_qdrant_key

# ─── MinIO (Object Storage) ───────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio

# ─── AI Provider APIs ─────────────────────────────────────────
# OpenAI — used for GPT-4o chat completions and text-embedding-3
OPENAI_API_KEY=sk-...

# Mistral AI — used for Mistral OCR and alternative embeddings
MISTRAL_API_KEY=...

# ─── Security ─────────────────────────────────────────────────
# Must be exactly 32 characters for AES-256 encryption
ENCRYPTION_KEY=change_me_32_chars_encryption_key

# HS256 JWT secret for internal service-to-service tokens
JWT_SECRET=change_me_jwt_secret

# ─── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=4000
CORS_ORIGIN=http://localhost

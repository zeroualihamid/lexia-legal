# ============================================================
# Lexia Legal AI Platform — Environment Variables Template
# Copy this file to .env and fill in the values before running
# ============================================================

# ─── PostgreSQL (Application Database) ───────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=legal_ai
POSTGRES_USER=legal_ai
POSTGRES_PASSWORD=change_me_secure_password

# ─── Keycloak (Identity & Access Management) ─────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=legal-ai
KEYCLOAK_CLIENT_ID=legal-ai-backend
KEYCLOAK_CLIENT_SECRET=change_me
KEYCLOAK_ADMIN_PASSWORD=change_me_admin
KEYCLOAK_DB_PASSWORD=change_me_kc_db

# Default Lexia Legal admin user (Keycloak realm `legal-ai`, seeded on boot)
LEXIA_DEV_USER=admin
LEXIA_DEV_PASSWORD=admin
LEXIA_DEV_EMAIL=admin@lexia.local

# ─── Redis (Queue & Cache) ────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis

# ─── Qdrant (Vector Database) ────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=change_me_qdrant_key

# ─── MinIO (Object Storage) ───────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio

# ─── AI Provider APIs ─────────────────────────────────────────
# OpenAI — used for GPT-4o chat completions and text-embedding-3
OPENAI_API_KEY=sk-...

# Mistral AI — used for Mistral OCR and alternative embeddings
MISTRAL_API_KEY=...

# ─── Security ─────────────────────────────────────────────────
# Must be exactly 32 characters for AES-256 encryption
ENCRYPTION_KEY=change_me_32_chars_encryption_key

# HS256 JWT secret for internal service-to-service tokens
JWT_SECRET=change_me_jwt_secret

# ─── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=4000
CORS_ORIGIN=http://localhost

# ─── Agent stack (deploy/docker-compose.yml) ──────────────────
# Better-auth DB for lexia-backend (separate from legal_ai schema)
LEXIA_BACKEND_DB=lexia_auth
BETTER_AUTH_SECRET=change_me_better_auth_secret
BETTER_AUTH_URL=http://localhost:6002
LEXIA_CHAT_ORIGIN=http://localhost:5173
LEXIA_ADMIN_ORIGIN=http://localhost:5175
LEXIA_BACKEND_PORT=6002
LEXIA_ADMIN_PORT=5175
LEXIA_AGENT_URL=http://lexia-agent:8000
# Shared secret for NestJS -> agent internal calls (user-document index/search).
# Must match on both lexia-backend and lexia-agent.
LEXIA_AGENT_INTERNAL_SECRET=change_me_agent_internal_secret
# Per-user/per-case document vector store (FastEmbed, 1024d) in Qdrant.
LEXIA_USER_DOCS_COLLECTION=lexia_user_docs
LEXIA_DOC_EMBED_MODEL=intfloat/multilingual-e5-large
# Monthly upload cap for authenticated users without an active paid plan.
LEXIA_DEFAULT_UPLOAD_QUOTA=100
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin
PGADMIN_PORT=5052
VERSION=latest
MINIO_BUCKET=lexia

# Optional chat LLM override (OpenAI-compatible). Point at DeepSeek or another
# provider for chat routing/answers. Embeddings always stay on OpenAI.
# DEEPSEEK_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com
# LLM_CHAT_MODEL=deepseek-chat

# Claude Code headless auth for bilingual judgment analysis. Generate with
# `claude setup-token` (requires a Claude subscription). If empty, judgment
# summaries fall back to the configured chat LLM (e.g. DeepSeek).
CLAUDE_CODE_OAUTH_TOKEN=
# Maximum runtime for one Claude judgment summary before DeepSeek fallback.
CLAUDE_ANALYSIS_TIMEOUT_MS=600000

# ─── Google Drive judgment import (scripts/import-gdrive-judgments.mjs) ──
# Share the Drive folder with the service account email, or use an access token.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_DRIVE_ACCESS_TOKEN=ya29...
# GOOGLE_DRIVE_FOLDER_ID=15V2YIi6eUwTKTWZ2Xd9A7Aflsl3Zp6Rh
# GDRIVE_JUDGMENTS_COLLECTION=judgments_commercial

FROM nginx:alpine

# envsubst ships in nginx:alpine (gettext). Remove the stock default server.
RUN rm -f /etc/nginx/conf.d/default.conf

COPY nginx.railway.conf.template /etc/nginx/railway.conf.template
COPY railway-entrypoint.sh /railway-entrypoint.sh
RUN chmod +x /railway-entrypoint.sh

EXPOSE 80

CMD ["/railway-entrypoint.sh"]

.06331646, -0.034896437, -0.028858148, 0.033319898, 0.073452346, -0.013402959, 0.020402933, 0.042190712, 0.018474344, 0.037712812, 0.02573293, -0.0079340255, -0.09419791, 0.026155476, -0.074534625, 0.015784089, -0.05856708, 0.03884963, 0.007789034, -0.04588713, 0.04019408, 0.09621519, -0.076489426, -0.051848914, 0.0047632693, -0.07132811, -0.019403888, -0.033510942, -0.066057876, 0.03782373, -0.05860274, -0.05113031, -0.05266245, 0.02035901, 0.034337457, 0.009152959, -0.046517015, -0.071477756, 0.06651307, 0.10180126, 0.042543165, -0.030234247, 0.061358407, 0.0057710903, -0.0025858493, -0.0002196755, -0.016390327, -0.051228393, 0.030787563, 0.010509137, -0.02055762, 0.08251689, -0.005560648, 0.05008426, 0.003953354, 0.001238245, -0.0064942287, 0.01665644, -0.003218004, -0.037097733, -0.056994244, -0.03890968, -0.05071843, 0.11726524, -0.015085842, 0.008932271, 0.028736556, 0.03302864, -0.05229058, -0.09830049, 0.020012667, 0.029415006, 0.01880779, -0.06668304, 0.013854145, 0.03429914, 0.014181211, 0.006780622, 0.03880415, 0.031817872, -0.027538545, 0.0074696164, 0.06624442, -0.04606301, -0.012125398, 0.042449147, 0.02760963]}</data>

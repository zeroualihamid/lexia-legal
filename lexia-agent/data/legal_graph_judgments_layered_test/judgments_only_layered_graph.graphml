0163, 0.052485194, 0.021313477, -0.060258422, 0.048753798, -0.07780649, 0.056021087, 0.07119237, -0.011563563, 0.035914753, 0.088721916, -0.0016207885, -0.0007872072, 0.025166633, -0.09911605, -0.03835524, 0.012192783, 0.034910694, -0.031857423, 0.030429998, -0.004082203, 0.01775488, -0.025080513, -0.01782342, -0.0836203, 0.048898313, 0.085947394, 0.008304753, 0.0027003267, -0.013541481, -0.0031128502, -0.06525456, -0.07837768, -0.103476666, 0.009704286, -0.014525409, -0.06557346, 0.04271681, -0.004988473, -0.047141712, -0.04970186, -0.037646104, 0.04393715, 0.07509882, 0.04664421, 0.0052652555, -0.07500568, -0.03350879, 0.019341897, -0.022499563, 0.0018702893, -0.040044367, -0.005774605, 0.026061941, 0.052845247, 0.021228617, 0.0121128345, -0.06937805, -0.03181878, 0.017849825, 0.03396556, 0.0031866038, -0.031220505, -0.013083219, -0.0069296365, 0.018056767, 0.11129781, 0.07203502, 0.004433294, -0.09419141, 0.010904136, 0.06454611, -0.031799957, -0.047557298, -0.028166136, -0.002420497, -0.016067455, 0.034742683, 0.015948521, 0.11084963, 0.02611513, -0.071506314, -0.018950652, -0.0031440703, 0.012194914, 0.02845545, 0.10737801]}</data>

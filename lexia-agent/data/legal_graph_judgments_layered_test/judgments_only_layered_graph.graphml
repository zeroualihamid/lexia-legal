 -0.00067528646, 0.023577832, 0.05016712, -0.013010178, 0.0045724656, 0.002353291, -0.013779489, 0.057139907, 0.037873812, 0.0071699955, 0.03522116, 0.0147306835, -0.032500934, 0.021083795, -0.08353465, 0.017490393, -0.047323164, 0.03514882, 0.031123394, 0.02357663, 0.031804424, 0.014918827, -0.065336965, -0.0035979422, -0.11276012, -0.009066288, 0.025216863, -0.040292963, 0.026250903, 0.010119538, -0.051271472, -0.018284794, -0.07196549, -0.05843932, -0.05726134, -0.031609148, -0.08508894, -0.06400419, 0.006680296, -0.05486518, -0.04413771, -0.029399753, -0.029608414, -0.0027024494, 0.0128801, 0.007958086, -0.08698503, 0.021199739, 0.03636317, -0.04272192, -0.03570678, -0.022544252, -0.026584152, 0.06507287, 0.054738756, 0.022537898, -0.034319762, -0.07749943, -0.017053643, -0.004059203, -0.023624655, 0.04063075, 0.024047844, 0.08002127, 0.017348537, 0.086523175, 0.06362984, 0.14595261, -0.009173978, -0.00043611968, -0.017249644, 0.039929483, 0.008829488, -0.082415186, -0.014350964, 0.057502404, -0.0037396138, 0.05106585, -0.011282391, -0.0029480597, -0.00707007, 0.012806453, 0.038282625, 0.016206156, -0.01728665, -0.0218433, 0.055579677]}</data>

1, -0.06279712, 0.03403929, 0.014838452, -0.033964712, 0.05250923, -0.056677938, 0.03766502, 0.059431743, 0.020337077, 0.01605639, 0.08472485, 0.015042146, -0.027667986, 0.06569017, -0.08359636, 0.0013602396, 0.015650455, 0.017293587, -0.045956537, -0.0035532007, 0.019886516, -0.027644834, -0.08236647, -0.012793648, -0.08857933, 0.014675721, 0.078860104, 0.03908791, 0.05516858, -0.034043036, -0.011410616, -0.03675365, -0.08854631, -0.035750482, -0.01204546, -0.017946545, -0.06808668, 0.0023316438, -0.023424564, -0.09231927, -0.0399936, -0.060002413, 0.021160733, 0.062825896, 0.05621879, 0.021341126, -0.09363039, 0.0017821698, 0.009753112, -0.047696993, 0.027379856, -0.07311658, -0.012252274, -0.00092366815, 0.04906727, 0.026603244, -0.009920548, -0.099521525, 0.008413633, -0.004893883, 0.029094325, -0.00069043576, -0.031782426, 0.0125904735, 0.014701621, 0.019627126, 0.11248335, 0.07652716, -0.014471415, -0.10630185, -0.01091812, 0.08531799, -0.04475019, -0.073579326, -0.017547237, 0.016600786, 0.0029204073, 0.03642867, 0.043081827, 0.08494531, 0.019107874, -0.08005745, -0.008939865, 0.0015621991, 0.00066263817, 0.002796917, 0.08083888]}</data>

8, -0.015911676, 0.031237341, 0.015451688, 0.019749733, 0.012739311, 0.0012900537, 0.026350461, 0.019919248, 0.0543495, 0.009637819, -0.040098887, 0.097209215, -0.11041329, 0.042822685, -0.017286908, 0.0608211, -0.006345928, 0.02813544, 0.0323665, 0.02158908, -0.05351838, 0.04234955, -0.016636446, 0.040074524, -0.012728302, -0.015883038, 0.017039822, -0.018351046, -0.06944513, -0.008743166, 0.018168867, -0.047513604, 0.015804239, -0.012267635, -0.12542711, -0.077621385, -0.021681666, -0.06979001, -0.026826883, -0.046445943, 0.024645856, 0.00402284, 0.05068371, -0.028695717, -0.08919943, -0.029294789, 0.04159812, 0.014740459, -0.00884401, -0.034373052, -0.02901989, -0.00844464, 0.001287828, 0.0127649745, -0.041471705, -0.02275049, -0.10618539, -0.06920642, -0.033134405, -0.019757122, -0.025353083, 0.029604949, 0.056353994, 0.06872822, -0.011928404, 0.11859665, 0.008922424, -0.027946066, -0.10436627, 0.047728237, 0.015503792, -0.031875327, -0.015424467, 0.049676992, 0.0186676, 0.00091001566, -0.009111339, -0.008620163, 0.027122555, -0.03055969, -0.024335423, -0.03370902, -0.06091527, 0.025965227, 0.040986493]}</data>

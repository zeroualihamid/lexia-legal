-0.011713599, -0.06309906, -0.05347955, 0.031385023, -0.018329358, 0.0095702745, 0.0136587, 0.020251082, 0.0046830997, 0.029743873, 0.060359735, 0.010441357, 0.010498811, 0.13735598, -0.04260268, -0.049231958, -0.012607899, 0.00375509, -0.0043582655, -0.03696236, 0.07231108, -0.008198671, -0.0949768, -0.046160858, 0.033792328, -0.07024037, -0.02031913, -0.019359767, -0.09413333, -0.0722442, -0.022134813, 0.12108178, -0.015970618, 0.039690297, 0.076201074, -0.055953655, 0.017543795, 0.014146361, 0.005595808, -0.06035525, 0.06919015, -0.08400069, -0.026750775, 0.14524893, 0.037374254, -0.02277161, -0.014057967, -0.018035218, -5.79222e-05, 0.060049698, 0.11629998, 0.022877127, 0.036699574, -0.0359806, -0.015576272, 0.045842867, -0.06876417, 0.016348349, 0.047850035, 0.032911126, -0.03270578, -0.026303716, -0.054929078, -0.06998194, 0.008304856, -0.0007777671, 0.046255976, -0.0046231593, -0.0017600834, -0.033542022, 0.11660911, 0.072100356, 0.014275651, -0.01156141, -0.0044479403, -0.030822556, 0.039960813, -0.012174308, 0.041117612, 0.04666172, -0.040897727, -0.04854855, 0.012520897, -0.046860028, -0.042875454, 0.07650612, 0.041736428]}</data>
